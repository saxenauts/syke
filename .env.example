# Optional one-shot provider override for the current shell.
# Setup normally prompts you to pick a provider interactively.
# SYKE_PROVIDER=codex

# Provider API keys (only needed for API-key providers).
# SYKE_OPENROUTER_API_KEY=sk-or-...
# SYKE_ZAI_API_KEY=...
# SYKE_KIMI_API_KEY=...

# GitHub personal access token (enables private repo ingestion).
GITHUB_TOKEN=ghp_...

# Gmail - the adapter picks the best available backend automatically.
#
# Option A (recommended): gog CLI - fast, handles keyring natively.
#   brew install gog && gog auth add --account your@gmail.com
GMAIL_ACCOUNT=your@gmail.com
#
# Option B: Python OAuth via env-provided desktop app credentials.
# GMAIL_CLIENT_ID=your-google-oauth-client-id
# GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
#
# Option C: Python OAuth via downloaded credentials JSON.
#   pip install google-auth-oauthlib google-api-python-client
#   Download from https://console.cloud.google.com/apis/credentials
# GMAIL_CREDENTIALS_PATH=~/.config/syke/gmail_credentials.json
# GMAIL_TOKEN_PATH=~/.config/syke/gmail_token.json

# Default user ID.
SYKE_USER=your-name-here

# Data directory (auto-detected: ./data for source installs, ~/.syke/data for pip).
# SYKE_DATA_DIR=./data
